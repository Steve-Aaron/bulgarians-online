# Survey & contact form webhook URL
# Create a Zapier (https://zapier.com) or Make (https://make.com) automation:
#   1. Trigger: "Webhooks by Zapier" -> "Catch Hook"
#   2. Action:  "Notion" -> "Create Database Item" -> select your database
#   3. Map the incoming JSON fields to your Notion properties
#   4. Copy the webhook URL here

VITE_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_WEBHOOK_ID/

# Optional: separate webhook URL for contact form (defaults to VITE_WEBHOOK_URL if not set)
# VITE_CONTACT_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_OTHER_WEBHOOK_ID/
